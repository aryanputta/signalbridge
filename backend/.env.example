# Copy this to .env and fill in values. The .env file is gitignored.

# Database path (default: local SQLite)
DB_PATH=sqlite:///./signalbridge.db

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: Anthropic API key for caregiver note parsing (LLM cache feature)
# Leave blank to disable note parsing
ANTHROPIC_API_KEY=
